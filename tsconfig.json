{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/schemas/*": ["src/schemas/*"],
      "@/lib/*": ["src/lib/*"],
      "@/routes/*": ["src/routes/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".keystone"]
}